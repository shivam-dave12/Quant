[Unit]
Description=Trading Dashboard V2 Backend
After=network.target

[Service]
Type=simple
User=__SERVICE_USER__
WorkingDirectory=__BOT_ROOT__/dashboard_v2/backend
Environment=DASHBOARD_PORT=8000
ExecStart=__BOT_ROOT__/dashboard_v2/backend/.venv/bin/python __BOT_ROOT__/dashboard_v2/backend/run.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
